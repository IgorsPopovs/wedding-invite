{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "wedding-invite",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "main": "./index.js",
  "assets": {
    "directory": "./",
    "binding": "ASSETS"
  }
}
